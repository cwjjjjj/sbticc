{
  "buildCommand": "bash build.sh",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/new", "destination": "/sbti", "permanent": true },
    { "source": "/new/love", "destination": "/love", "permanent": true },
    { "source": "/new/work", "destination": "/work", "permanent": true },
    { "source": "/new/values", "destination": "/values", "permanent": true },
    { "source": "/new/cyber", "destination": "/cyber", "permanent": true },
    { "source": "/new/desire", "destination": "/desire", "permanent": true },
    { "source": "/new/gsti", "destination": "/gsti", "permanent": true },
    { "source": "/new/fpi", "destination": "/fpi", "permanent": true },
    { "source": "/new/fsi", "destination": "/fsi", "permanent": true },
    { "source": "/new/mpi", "destination": "/mpi", "permanent": true },
    { "source": "/new/xpti", "destination": "/xpti", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/sbti", "destination": "/new/index.html" },
    { "source": "/love", "destination": "/new/love/index.html" },
    { "source": "/love/(.*)", "destination": "/new/love/index.html" },
    { "source": "/work", "destination": "/new/work/index.html" },
    { "source": "/work/(.*)", "destination": "/new/work/index.html" },
    { "source": "/values", "destination": "/new/values/index.html" },
    { "source": "/values/(.*)", "destination": "/new/values/index.html" },
    { "source": "/cyber", "destination": "/new/cyber/index.html" },
    { "source": "/cyber/(.*)", "destination": "/new/cyber/index.html" },
    { "source": "/desire", "destination": "/new/desire/index.html" },
    { "source": "/desire/(.*)", "destination": "/new/desire/index.html" },
    { "source": "/gsti", "destination": "/new/gsti/index.html" },
    { "source": "/gsti/(.*)", "destination": "/new/gsti/index.html" },
    { "source": "/fpi", "destination": "/new/fpi/index.html" },
    { "source": "/fpi/(.*)", "destination": "/new/fpi/index.html" },
    { "source": "/fsi", "destination": "/new/fsi/index.html" },
    { "source": "/fsi/(.*)", "destination": "/new/fsi/index.html" },
    { "source": "/mpi", "destination": "/new/mpi/index.html" },
    { "source": "/mpi/(.*)", "destination": "/new/mpi/index.html" },
    { "source": "/xpti", "destination": "/new/xpti/index.html" },
    { "source": "/xpti/(.*)", "destination": "/new/xpti/index.html" },
    { "source": "/new/((?!assets/).*)", "destination": "/new/index.html" }
  ]
}
