{
  "buildCommand": "bash build.sh",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/new/:path*", "destination": "/:path*", "permanent": true },
    { "source": "/new", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/love", "destination": "/love/index.html" },
    { "source": "/work", "destination": "/work/index.html" },
    { "source": "/values", "destination": "/values/index.html" },
    { "source": "/cyber", "destination": "/cyber/index.html" },
    { "source": "/desire", "destination": "/desire/index.html" },
    { "source": "/mbti", "destination": "/mbti/index.html" },
    { "source": "/((?!api|assets|images|love|work|values|cyber|desire|mbti|sw\\.js).*)", "destination": "/index.html" }
  ]
}
