{
  "buildCommand": "bash build.sh",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/new", "destination": "/new/index.html" },
    { "source": "/new/love", "destination": "/new/love/index.html" },
    { "source": "/new/love/(.*)", "destination": "/new/love/index.html" },
    { "source": "/new/work", "destination": "/new/work/index.html" },
    { "source": "/new/work/(.*)", "destination": "/new/work/index.html" },
    { "source": "/new/values", "destination": "/new/values/index.html" },
    { "source": "/new/values/(.*)", "destination": "/new/values/index.html" },
    { "source": "/new/cyber", "destination": "/new/cyber/index.html" },
    { "source": "/new/cyber/(.*)", "destination": "/new/cyber/index.html" },
    { "source": "/new/desire", "destination": "/new/desire/index.html" },
    { "source": "/new/desire/(.*)", "destination": "/new/desire/index.html" },
    { "source": "/new/gsti", "destination": "/new/gsti/index.html" },
    { "source": "/new/gsti/(.*)", "destination": "/new/gsti/index.html" },
    { "source": "/new/fpi", "destination": "/new/fpi/index.html" },
    { "source": "/new/fpi/(.*)", "destination": "/new/fpi/index.html" },
    { "source": "/new/fsi", "destination": "/new/fsi/index.html" },
    { "source": "/new/fsi/(.*)", "destination": "/new/fsi/index.html" },
    { "source": "/new/((?!assets/).*)", "destination": "/new/index.html" }
  ]
}
