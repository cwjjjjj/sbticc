{
  "buildCommand": "cd packages/taro-app && pnpm build:h5",
  "outputDirectory": "packages/taro-app/dist",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "api/*.js": {
      "memory": 128
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
